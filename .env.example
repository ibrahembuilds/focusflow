# Server-only OpenRouter key. Do not prefix this with VITE_.
OPENROUTER_API_KEY=replace_with_your_key

# Optional model override.
OPENROUTER_MODEL=openai/gpt-4o-mini

# Supabase — find these in your Supabase dashboard under Project Settings > API.
# The VITE_ prefix is required so the browser app can read them.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Add these when the Hostinger database integration is implemented.
# DATABASE_HOST=your_mysql_hostname
# DATABASE_PORT=3306
# DATABASE_NAME=your_database_name
# DATABASE_USER=your_database_user
# DATABASE_PASSWORD=your_database_password
